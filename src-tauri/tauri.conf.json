{
  "productName": "LC-MS Screening Assistant",
  "version": "1.0.0",
  "identifier": "com.vkey.lscreening",
  "build": {
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LC-MS Screening Assistant",
        "width": 1080,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "pyembed/python": "./"
    }
  }
}
