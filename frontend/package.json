{
  "name": "frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build src/lib/screening-wasm --target web --out-dir ../wasm-pkg",
    "dev": "bun run build:wasm && vite dev",
    "build": "bun run build:wasm && vite build",
    "build:standalone": "bun run build:wasm && VITE_STANDALONE=true vite build",
    "build:singlepage": "bun run build:wasm && VITE_STANDALONE=true vite build && node scripts/inline-standalone.mjs",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2"
  },
  "dependencies": {
    "@json-render/core": "^0.16.0",
    "@json-render/svelte": "^0.16.0",
    "lucide-svelte": "^1.0.1",
    "tauri-plugin-pytauri-api": "^0.8.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  }
}
